// vocallm/prisma/schema.prisma
// Full multi-tenant schema for the VoCallM white-label AI calling platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// TENANT (each of your clients is one tenant)
// ─────────────────────────────────────────────
model Tenant {
  id              String    @id @default(cuid())
  name            String                          // "Acme Plumbing"
  slug            String    @unique               // "acme-plumbing" — used in subdomain
  domain          String?   @unique               // "calls.acmeplumbing.com" — custom domain
  logoUrl         String?                         // uploaded logo for white-label portal
  primaryColor    String    @default("#1a2b4a")   // hex — portal brand colour
  
  // Contact
  ownerName       String
  ownerEmail      String    @unique
  ownerPhone      String?

  // Billing
  ratePerMinute   Float     @default(0.30)        // what YOU charge this client per minute
  billingEmail    String?
  totalMinutes    Float     @default(0)           // running total billed minutes
  
  // Status
  status          TenantStatus @default(ACTIVE)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Calendar / CRM integration (optional per client)
  calcomApiKey        String?
  calcomEventTypeId   String?
  hubspotAccessToken  String?
  googleCalendarToken String?

  // Stripe billing
  stripeCustomerId      String?   @unique
  stripeSubscriptionId  String?   @unique

  // Plan (self-service signup)
  planId          String?
  plan            Plan?     @relation(fields: [planId], references: [id])
  planExpiresAt   DateTime?   // set from Stripe current_period_end; null = free/never expires

  // Cloned voice (ElevenLabs Instant Voice Cloning)
  clonedVoiceId   String?   // ElevenLabs voice_id
  clonedVoiceName String?   // human-readable name the client gave it

  // WhatsApp — client-submitted number request (admin reads this and sets WaTenantConfig)
  waRequestedPhone String?

  // Relations
  phoneNumbers         TenantPhone[]
  campaigns            Campaign[]
  leads                Lead[]
  calls                Call[]
  scripts              Script[]
  users                TenantUser[]
  inboundPhoneNumbers  InboundPhoneNumber[]
  inboundAssistants    InboundAssistant[]
  inboundCalls         InboundCall[]
  leadBatches          LeadBatch[]
  waContactLists       WaContactList[]
  waCampaigns          WaCampaign[]
  waTemplateRequests   WaTemplateRequest[]
  waTenantConfig       WaTenantConfig?
}

enum TenantStatus {
  ACTIVE
  PAUSED
  SUSPENDED
}

// ─────────────────────────────────────────────
// TENANT PHONE NUMBERS
// Each client can have multiple numbers (US, CA, UAE etc)
// ─────────────────────────────────────────────
model TenantPhone {
  id            String    @id @default(cuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  
  number        String    @unique   // E.164 format: +12125550100
  friendlyName  String              // "US - New York (212)"
  country       String              // "US" | "CA" | "IN"
  provider      String    @default("TWILIO")  // "TWILIO" | "PLIVO"
  twilioSid     String?             // Twilio SID (TWILIO provider)
  plivoUuid     String?             // Plivo UUID (PLIVO provider)
  vapiNumberId  String?             // Vapi phone number ID

  isDefault     Boolean   @default(false)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())

  calls         Call[]
}

// ─────────────────────────────────────────────
// TENANT USERS (who can log into the client portal)
// ─────────────────────────────────────────────
model TenantUser {
  id            String    @id @default(cuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  
  email         String
  passwordHash  String
  name          String
  role          TenantUserRole @default(VIEWER)
  
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())

  @@unique([tenantId, email])
}

enum TenantUserRole {
  OWNER     // can upload leads, edit scripts, view billing
  VIEWER    // read-only — sees reports only
}

// ─────────────────────────────────────────────
// SUPER ADMIN USERS (Wayne Solutions team)
// ─────────────────────────────────────────────
model AdminUser {
  id                   String    @id @default(cuid())
  email                String    @unique
  passwordHash         String
  name                 String
  passwordResetToken   String?   @unique
  passwordResetExpiry  DateTime?
  createdAt            DateTime  @default(now())
}

// ─────────────────────────────────────────────
// SCRIPT
// Client writes this in plain English — your system
// wraps it in the full system prompt automatically
// ─────────────────────────────────────────────
model Script {
  id            String        @id @default(cuid())
  tenantId      String
  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  
  name          String                    // "Q4 2026 Campaign Script"
  
  // What the client writes
  companyInfo   String        @db.Text    // "We are a plumbing company in Toronto..."
  servicesInfo  String        @db.Text    // "We offer emergency repairs, pipe installation..."
  goalText      String        @db.Text    // "Book a free quote appointment"
  objections    String?       @db.Text    // "If they say they have a provider, say..."
  faqDocument   String?       @db.Text    // uploaded FAQ doc content (parsed from PDF/txt)
  faqFileUrl    String?                   // original uploaded file URL
  
  // Voice config
  voiceId       String        @default("Zfdm6VIqhPJ3dNiRCAN7")  // ElevenLabs voice ID
  agentName     String        @default("Alex")                    // name the caller uses
  agentGender   String        @default("female")                  // "male" | "female" — affects Hindi/Punjabi verb forms
  language      String        @default("en")                      // BCP-47 code: "en", "hi", "es", "fr", etc.
  
  // Approval workflow
  status        ScriptStatus  @default(PENDING_REVIEW)
  reviewNote    String?       // admin note when rejecting
  reviewedBy    String?       // admin user id
  reviewedAt    DateTime?
  
  // Max call duration in seconds (controls Vapi assistant maxDurationSeconds)
  maxCallDuration Int         @default(180)

  // Compiled system prompt (generated by your system, never shown to client)
  compiledPrompt String?      @db.Text

  isActive      Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  campaigns     Campaign[]
}

enum ScriptStatus {
  PENDING_REVIEW    // client submitted, waiting for your approval
  APPROVED          // you approved it, ready to use
  REJECTED          // you rejected it with a note
  LIVE              // currently being used in an active campaign
}

// ─────────────────────────────────────────────
// CAMPAIGN
// A campaign = a script + a set of leads + calling rules
// ─────────────────────────────────────────────
model Campaign {
  id              String          @id @default(cuid())
  tenantId        String
  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  scriptId        String
  script          Script          @relation(fields: [scriptId], references: [id])
  
  name            String          // "Toronto leads Oct 2026"
  
  // Calling schedule
  callFromHour    Int             @default(9)   // 9 = 9am in client's timezone
  callToHour      Int             @default(17)  // 17 = 5pm
  timezone        String          @default("America/Toronto")
  callDays        String          @default("MON,TUE,WED,THU,FRI")  // comma-separated
  maxAttempts     Int             @default(3)   // max retries per lead
  retryAfterHours Int             @default(24)  // wait before retry
  
  status          CampaignStatus  @default(DRAFT)
  startedAt       DateTime?
  pausedAt        DateTime?
  completedAt     DateTime?
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  leads           Lead[]
  calls           Call[]
}

enum CampaignStatus {
  DRAFT       // created but not started
  ACTIVE      // currently dialling
  PAUSED      // manually paused
  COMPLETED   // all leads exhausted
}

// ─────────────────────────────────────────────
// LEAD
// Individual person to be called
// ─────────────────────────────────────────────
model LeadBatch {
  id          String   @id @default(cuid())
  tenantId    String
  filename    String
  totalCount  Int      @default(0)
  createdAt   DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  leads       Lead[]
}

model Lead {
  id              String      @id @default(cuid())
  tenantId        String
  tenant          Tenant      @relation(fields: [tenantId], references: [id])
  campaignId      String?
  campaign        Campaign?   @relation(fields: [campaignId], references: [id])
  uploadBatchId   String?
  uploadBatch     LeadBatch?  @relation(fields: [uploadBatchId], references: [id])
  
  // Contact info
  name            String
  phone           String                // E.164 format
  email           String?
  company         String?
  title           String?               // "CTO", "IT Manager" etc
  country         String    @default("US")  // "US" | "CA" | "UAE"
  
  // DNC
  isOptedOut      Boolean   @default(false)
  optedOutAt      DateTime?
  
  // Call tracking
  status          LeadStatus  @default(PENDING)
  callAttempts    Int         @default(0)
  lastCalledAt    DateTime?
  callbackAt      DateTime?             // scheduled callback time
  
  // Outcome
  meetingBookedAt DateTime?
  meetingLink     String?
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  calls           Call[]

  @@index([tenantId])
  @@index([campaignId])
  @@index([tenantId, status])
}

enum LeadStatus {
  PENDING           // not yet called
  CALLING           // currently on a call
  BOOKED            // meeting booked — success
  NOT_INTERESTED    // said no
  CALLBACK          // asked to call back later
  VOICEMAIL         // left voicemail
  NO_ANSWER         // rang out, no answer
  WRONG_NUMBER      // not the right person/number
  OPTED_OUT         // asked not to be called
  EXHAUSTED         // max attempts reached
}

// ─────────────────────────────────────────────
// CALL
// Every call attempt is one record
// ─────────────────────────────────────────────
model Call {
  id              String      @id @default(cuid())
  tenantId        String
  tenant          Tenant      @relation(fields: [tenantId], references: [id])
  leadId          String
  lead            Lead        @relation(fields: [leadId], references: [id])
  campaignId      String?
  campaign        Campaign?   @relation(fields: [campaignId], references: [id])
  phoneNumberId   String?
  phoneNumber     TenantPhone? @relation(fields: [phoneNumberId], references: [id])
  
  // Provider IDs
  twilioCallSid   String?     @unique
  vapiCallId      String?     @unique
  
  // Call data
  direction       String      @default("outbound")
  durationSeconds Int?
  status          CallStatus  @default(INITIATED)
  outcome         CallOutcome?
  
  // Content
  transcript      String?     @db.Text    // full conversation text
  summary         String?     @db.Text    // AI-generated 1-paragraph summary
  recordingUrl    String?
  
  // Meeting booked during this call
  meetingBookedAt    DateTime?   // when the booking was created
  scheduledMeetingAt DateTime?   // actual scheduled meeting datetime (from Cal.com or preferred_slot)
  meetingLink        String?
  calEventId         String?
  
  // Billing
  billedMinutes   Float?      // rounded up to nearest 0.1 min
  billedAmount    Float?      // billedMinutes * tenant.ratePerMinute
  
  sentimentLog    Json?       // array of { ts, sentiment, intent, buying_signal, suggested_action }

  startedAt       DateTime?
  endedAt         DateTime?
  createdAt       DateTime    @default(now())

  @@index([tenantId])
  @@index([campaignId])
  @@index([tenantId, status])
  @@index([campaignId, status, outcome])
  @@index([createdAt])
}

enum CallStatus {
  INITIATED     // call triggered
  RINGING       // dialling
  IN_PROGRESS   // prospect answered
  COMPLETED     // call ended normally
  NO_ANSWER     // rang out
  FAILED        // technical failure
  VOICEMAIL     // went to voicemail
}

enum CallOutcome {
  BOOKED
  NOT_INTERESTED
  CALLBACK
  VOICEMAIL
  NO_ANSWER
  WRONG_NUMBER
  OPTED_OUT
  ERROR
}

// ─────────────────────────────────────────────
// PLAN
// Subscription tiers shown on the public pricing page.
// Admin creates/edits; tenants pick one at self-service signup.
// ─────────────────────────────────────────────
model Plan {
  id              String    @id @default(cuid())
  name            String                        // "Starter"
  blurb           String?                       // "Test the waters"
  price           Float                         // rate per minute charged to client
  minutesIncluded Int       @default(0)         // 0 = unlimited / pay-as-you-go
  features        Json                          // ["1 phone number", "1 campaign", ...]
  isActive        Boolean   @default(true)
  isPopular       Boolean   @default(false)
  displayOrder    Int       @default(0)
  stripePriceId   String?   // cached Stripe recurring price ID
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenants         Tenant[]
}

// ─────────────────────────────────────────────
// INBOUND — Phone Numbers
// ─────────────────────────────────────────────
model InboundPhoneNumber {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  phoneNumber String   @unique
  country     String   @default("CA")
  twilioSid   String?
  vapiPhoneId String?
  provider    String   @default("twilio")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  assistants  InboundAssistant[]
  calls       InboundCall[]
}

// ─────────────────────────────────────────────
// INBOUND — AI Receptionist Config
// ─────────────────────────────────────────────
model InboundAssistant {
  id            String              @id @default(cuid())
  tenantId      String
  tenant        Tenant              @relation(fields: [tenantId], references: [id])
  phoneNumberId String?
  phoneNumber   InboundPhoneNumber? @relation(fields: [phoneNumberId], references: [id])

  agentName     String  @default("Alex")
  language      String  @default("en")
  voiceId       String?
  agentGender   String  @default("female")

  businessName    String
  businessType    String?
  servicesInfo    String?  @db.Text
  faqText         String?  @db.Text
  businessHours   Json?

  transferNumber  String?
  transferMessage String?
  bookingUrl      String?
  maxCallDuration Int     @default(300)

  firstMessage    String?  @db.Text
  systemPrompt    String?  @db.Text
  vapiAssistantId String?

  status        String   @default("draft")  // draft | active | paused
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  calls         InboundCall[]
}

// ─────────────────────────────────────────────
// INBOUND — Call Records
// ─────────────────────────────────────────────
model InboundCall {
  id              String              @id @default(cuid())
  tenantId        String
  tenant          Tenant              @relation(fields: [tenantId], references: [id])
  assistantId     String?
  assistant       InboundAssistant?   @relation(fields: [assistantId], references: [id])
  phoneNumberId   String?
  phoneNumber     InboundPhoneNumber? @relation(fields: [phoneNumberId], references: [id])

  vapiCallId      String?  @unique
  callerNumber    String?
  calledNumber    String?

  durationSeconds Int?
  outcome         String?  // COMPLETED | TRANSFERRED | VOICEMAIL | NO_ANSWER | FAILED
  summary         String?  @db.Text
  transcript      Json?
  recordingUrl    String?
  costUsd         Float?

  startedAt       DateTime?
  endedAt         DateTime?
  createdAt       DateTime @default(now())

  @@index([tenantId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// USAGE LOG
// Append-only log of every billed minute block
// ─────────────────────────────────────────────
model UsageLog {
  id            String    @id @default(cuid())
  tenantId      String
  callId        String

  minutes       Float
  ratePerMinute Float
  amount        Float

  createdAt     DateTime  @default(now())

  @@index([tenantId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// WHATSAPP OUTREACH
// Compliance-gated: a contact may ONLY be messaged on WhatsApp after
// VoCallM confirms a verbal opt-in (optInStatus = OPTED_IN).
// The ONLY code path that may set OPTED_IN is src/services/waOptIn.js.
// The ONLY module that calls Meta's send endpoint is src/services/waWhatsapp.js,
// and its query is hard-filtered to { optInStatus: "OPTED_IN", optedOut: false }.
// ─────────────────────────────────────────────

model WaContactList {
  id             String    @id @default(cuid())
  tenantId       String
  tenant         Tenant    @relation(fields: [tenantId], references: [id])
  name           String
  sourceFilename String?
  uploadedAt     DateTime  @default(now())
  totalContacts  Int       @default(0)

  contacts       WaContact[]

  @@index([tenantId])
}

model WaContact {
  id            String          @id @default(cuid())
  contactListId String
  contactList   WaContactList   @relation(fields: [contactListId], references: [id], onDelete: Cascade)
  tenantId      String

  fullName     String?
  phone        String
  businessName String?
  tags         String?

  optInStatus       WaOptInStatus @default(NOT_CONTACTED)
  optedOut          Boolean       @default(false)
  optInSource       String?
  optInTimestamp    DateTime?
  optInCallId       String?
  optInRecordingUrl String?

  serviceWindowExpiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  callAttempts WaCallAttempt[]
  messages     WaMessage[]

  @@unique([contactListId, phone])
  @@index([tenantId])
  @@index([optInStatus])
  @@index([phone])
}

model WaCallAttempt {
  id            String    @id @default(cuid())
  contactId     String
  contact       WaContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  vocallmCallId String?
  outcome       String?
  transcript    String?   @db.Text
  recordingUrl  String?
  placedAt      DateTime  @default(now())
  completedAt   DateTime?

  @@index([contactId])
  @@index([vocallmCallId])
}

model WaCampaign {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  name         String
  templateName String
  languageCode String   @default("en")
  createdAt    DateTime @default(now())

  messages     WaMessage[]

  @@index([tenantId])
}

model WaMessage {
  id          String             @id @default(cuid())
  contactId   String
  contact     WaContact          @relation(fields: [contactId], references: [id], onDelete: Cascade)
  campaignId  String?
  campaign    WaCampaign?        @relation(fields: [campaignId], references: [id])
  tenantId    String

  direction   WaMessageDirection
  status      WaMessageStatus    @default(QUEUED)
  waMessageId String?
  templateName String?
  body        String?            @db.Text
  error       String?            @db.Text
  createdAt   DateTime           @default(now())

  @@index([tenantId])
  @@index([contactId])
  @@index([waMessageId])
}

enum WaOptInStatus {
  NOT_CONTACTED
  PENDING
  OPTED_IN
  DECLINED
  NO_ANSWER
  VOICEMAIL
  NEEDS_MANUAL_REVIEW
  FAILED
}

enum WaMessageDirection {
  OUTBOUND
  INBOUND
}

enum WaMessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
  RECEIVED
}

// ─────────────────────────────────────────────
// ADMIN ALERTS
// Platform-level alerts for the super admin (low credits, high spend)
// ─────────────────────────────────────────────
model AdminAlert {
  id        String   @id @default(cuid())
  type      String   // "ELEVENLABS_LOW" | "VAPI_HIGH"
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([isRead])
  @@index([createdAt])
}

enum WaTemplateStatus {
  DRAFT
  PENDING_ADMIN
  ADMIN_REJECTED
  SUBMITTED_TO_META
  APPROVED
  META_REJECTED
}

// Per-tenant WhatsApp credentials — falls back to env vars when absent
model WaTenantConfig {
  id            String   @id @default(cuid())
  tenantId      String   @unique
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  wabaId        String?
  phoneNumberId String?
  accessToken   String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model WaTemplateRequest {
  id                  String           @id @default(cuid())
  tenantId            String
  tenant              Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name                String
  category            String           @default("MARKETING")
  languageCode        String           @default("en")
  headerText          String?
  bodyText            String           @db.Text
  footerText          String?
  buttons             Json?
  status              WaTemplateStatus @default(DRAFT)
  adminNote           String?          @db.Text
  metaTemplateId      String?
  metaStatus          String?
  metaRejectionReason String?          @db.Text
  submittedAt         DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@index([tenantId])
  @@index([status])
}
