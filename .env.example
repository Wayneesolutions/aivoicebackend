# ── DATABASE ──────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/vocallm

# ── SERVER ────────────────────────────────────────────────
PORT=3001
BASE_URL=https://api.yourdomain.com
FRONTEND_ADMIN_URL=https://admin.yourdomain.com
FRONTEND_CLIENT_URL=https://app.yourdomain.com
JWT_SECRET=replace_with_long_random_string_min_64_chars
JWT_EXPIRES_IN=7d

# ── REDIS (for Bull queue) ────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── TWILIO ────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── VAPI ──────────────────────────────────────────────────
VAPI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPI_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── DEEPGRAM ──────────────────────────────────────────────
DEEPGRAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── OPENAI ────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── ELEVENLABS ────────────────────────────────────────────
ELEVENLABS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Default voice (used if client doesn't set one)
ELEVENLABS_DEFAULT_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── CALCOM (Wayne Solutions master account) ───────────────
CALCOM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CALCOM_EVENT_TYPE_ID=123456
CALCOM_USERNAME=waynesolutions

# ── HUBSPOT (Wayne Solutions master account) ──────────────
HUBSPOT_ACCESS_TOKEN=pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── FILE UPLOADS ──────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ── PLATFORM COSTS (what YOU pay per minute, for margin tracking) ──
PLATFORM_COST_PER_MINUTE=0.12
