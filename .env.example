# ── DATABASE ──────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/vocallm

# ── SERVER ────────────────────────────────────────────────
PORT=3001
# Public-facing URL of the backend — used as the Vapi webhook base URL.
# Must be a permanent domain in production. Changing it requires re-approving
# all scripts so Vapi picks up the new webhook address.
BASE_URL=https://api.yourdomain.com
FRONTEND_ADMIN_URL=https://admin.yourdomain.com
FRONTEND_CLIENT_URL=https://app.yourdomain.com
# Root domain for the CORS subdomain allowlist (without leading dot).
# e.g. "yourdomain.com" allows *.yourdomain.com for white-label portals.
DOMAIN=yourdomain.com
JWT_SECRET=replace_with_long_random_string_min_64_chars
JWT_EXPIRES_IN=7d

# ── ADMIN SEED ────────────────────────────────────────────
# Required as x-seed-secret header to call POST /api/auth/admin/seed (one-time bootstrap).
# Not used in normal operation — you can remove it after the admin user is created.
ADMIN_SEED_SECRET=replace_with_a_strong_random_secret

# ── REDIS (required for Bull dial queue) ──────────────────
REDIS_URL=redis://localhost:6379

# ── PLIVO ─────────────────────────────────────────────────
PLIVO_AUTH_ID=MAXXXXXXXXXXXXXXXXXX
PLIVO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Required only to BUY Plivo numbers through Vapi.
# Setup: Vapi Dashboard → Credentials → Add Plivo SIP trunk → paste the credential ID here.
# Leave blank if you only use Twilio.
PLIVO_VAPI_CREDENTIAL_ID=

# ── TWILIO ────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── VAPI ──────────────────────────────────────────────────
VAPI_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Paste this SAME value into Vapi Dashboard → Settings → Webhooks → Secret.
VAPI_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: Vapi credential ID for your ElevenLabs account.
# Get from Vapi Dashboard → Credentials → ElevenLabs. Leave blank to use Vapi's built-in.
VAPI_ELEVENLABS_CREDENTIAL_ID=
#
# NOTE — OpenAI and Deepgram are NOT configured here.
# Vapi handles both services internally via its own integrations.
# Add your OpenAI and Deepgram API keys directly in the Vapi Dashboard instead.

# ── ELEVENLABS ────────────────────────────────────────────
# Used directly by the backend for tenant voice cloning (POST /api/tenant/voice).
# Still used for ALL English calls, and as automatic fallback for Hindi/Punjabi
# calls if Cartesia TTS errors or times out mid-call.
ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Default voice ID used when a script has no voice set.
ELEVENLABS_DEFAULT_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# Optional: separate ElevenLabs voice ID confirmed multilingual, used as the
# fallback voice for Hindi/Punjabi if Cartesia errors mid-call.
ELEVENLABS_HINDI_VOICE_ID=

# ── CARTESIA AI (Hindi/Punjabi TTS — English keeps ElevenLabs) ────────
# Cartesia is a NATIVE Vapi voice provider — no
# custom webhook to host, Vapi streams directly from Cartesia. Sub-100ms
# time-to-first-audio, native Hindi + Punjabi + Hinglish support.
#
# ONE-TIME SETUP REQUIRED before CARTESIA_TTS_ENABLED=true will work:
#   1. Get an API key from https://play.cartesia.ai/keys
#   2. Add it in Vapi Dashboard → Provider Keys → Cartesia (this lets Vapi
#      call Cartesia on our behalf — it is NOT read from this .env file).
#   3. Pick Hindi and Punjabi voice IDs from https://play.cartesia.ai
#      (Voice Library) and paste them below.
#
# Set CARTESIA_TTS_ENABLED=false to instantly revert Hindi/Punjabi calls
# back to ElevenLabs with no code change — useful for A/B testing or rollback.
CARTESIA_TTS_ENABLED=false
CARTESIA_MODEL=sonic-3.5
# Optional: only needed if you added the Cartesia key as a named credential
# in Vapi Dashboard → Credentials rather than the account-level Provider Key.
VAPI_CARTESIA_CREDENTIAL_ID=
# Per-language, per-gender voice IDs (from Cartesia Voice Library).
CARTESIA_HI_VOICE_FEMALE=
CARTESIA_HI_VOICE_MALE=
CARTESIA_PA_VOICE_FEMALE=
CARTESIA_PA_VOICE_MALE=
# Used if a specific language/gender voice above isn't set.
CARTESIA_DEFAULT_VOICE_ID=

# ── CALCOM (Wayne Solutions master account) ───────────────
CALCOM_API_KEY=cal_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CALCOM_EVENT_TYPE_ID=123456
# Your Cal.com username — the slug after cal.com/ in your profile URL.
CALCOM_USERNAME=waynesolutions

# ── HUBSPOT (Wayne Solutions master account) ──────────────
HUBSPOT_ACCESS_TOKEN=pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── STRIPE ────────────────────────────────────────────────
# Use sk_test_... during development, sk_live_... in production.
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=<your-stripe-secret-key>
# Get from https://dashboard.stripe.com/webhooks after registering your endpoint URL.
STRIPE_WEBHOOK_SECRET=<your-stripe-webhook-secret>

# ── AWS S3 (logo uploads — falls back to local disk if unset) ─
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_REGION=us-east-1
AWS_S3_BUCKET=vocallm-uploads

# ── SMTP ──────────────────────────────────────────────────
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=yourpassword
SMTP_FROM=VoCallM <noreply@yourdomain.com>

# ── FILE UPLOADS ──────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ── PLATFORM COSTS ────────────────────────────────────────
PLATFORM_COST_PER_MINUTE=0.12

# ── WHATSAPP CLOUD API (Meta) ──────────────────────────────
# How to get these — see "Third-Party API Setup Guide" below.
# Graph API version — v21.0 is current stable as of 2026.
WA_GRAPH_VERSION=v21.0
# Phone Number ID from: Meta App Dashboard → WhatsApp → API Setup → "From" section
WA_PHONE_NUMBER_ID=
# Permanent system-user access token (NOT the temporary 24-h token).
# Meta App Dashboard → Business Settings → System Users → generate token with whatsapp_business_messaging scope.
WA_ACCESS_TOKEN=
# App Secret from: Meta App Dashboard → App Settings → Basic → App Secret
WA_APP_SECRET=
# Your own verification string — paste the same value into Meta App Dashboard
# → WhatsApp → Configuration → Webhook → Verify Token.
WA_VERIFY_TOKEN=replace_with_your_own_random_string
# Concurrent sends to stay under Meta's ~80 msg/sec limit (default 10 is safe).
WA_SEND_CONCURRENCY=10
# Default country code for parsing phone numbers without a country prefix.
# Use ISO 3166-1 alpha-2: US, CA, IN, GB, etc.
WA_DEFAULT_COUNTRY=US

# ── WHATSAPP OPT-IN ASSISTANT (Vapi) ──────────────────────
# Vapi assistant ID for the opt-in confirmation call.
# Create in Vapi Dashboard → Assistants → New Assistant.
# Set its Server URL to: https://YOUR_DOMAIN/api/whatsapp/webhooks/vapi-optin
# Give it one tool: record_consent({ decision: "yes"|"no"|"unclear" })
# Paste the generated assistant ID here.
WA_OPTIN_ASSISTANT_ID=
